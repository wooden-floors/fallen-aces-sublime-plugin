  "shortcuts": [
    {"trigger": "todo", "contents": "// TODO: ${1}"},
    {"trigger": "ife", "contents": "If(Equal(${1:value1}, ${2:value2}))\n{\n\t${3:body}\n}", "annotation": "If Equals"},
    {"trigger": "ifne", "contents": "If(!Equal(${1:value1}, ${2:value2}))\n{\n\t${3:body}\n}", "annotation": "If Not Equals"},
    {"trigger": "ifl", "contents": "If(Less(${1:value1}, ${2:value2}))\n{\n\t${3:body}\n}", "annotation": "If Less"},
    {"trigger": "ifle", "contents": "If(LessOrEqual(${1:value1}, ${2:value2}))\n{\n\t${3:body}\n}", "annotation": "If Less Or Equal"},
    {"trigger": "ifg", "contents": "If(Greater(${1:value1}, ${2:value2}))\n{\n\t${3:body}\n}", "annotation": "If Greater"},
    {"trigger": "ifge", "contents": "If(GreaterOrEqual(${1:value1}, ${2:value2}))\n{\n\t${3:body}\n}", "annotation": "If Greater Or Equal"},
    {"trigger": "wht", "contents": "While(Equal(1, 1))\n{\n\t${1:body}\n}", "annotation": "While True"},
    {"trigger": "inc", "contents": "Add(\"&${1}\", 1);", "annotation": "Increment"},
    {"trigger": "dec", "contents": "Subtract(\"&${1}\", 1);", "annotation": "Decrement"},
    {"trigger": "main", "contents": "Main(${1:args})\n{\n\t${2:body}\n}"}
  ],
