    {
      "name": "SetLocalVariable",
      "variants": [
        {
          "args": ["name", "value"],
          "description": "Sets a local variable that can be read from the same script.",
          "usage": "SetLocalVariable(\"phone_is_ringing\", 1);\n\nIf(Equal(\"phone_is_ringing\", 1))\n{\n    ...\n}"
        }
      ]
    },
